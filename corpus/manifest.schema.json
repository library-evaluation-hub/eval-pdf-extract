{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://library-evaluation-hub/eval-pdf-extract/corpus-manifest.schema.json",
  "title": "Corpus Manifest",
  "description": "corpus/manifest.json 的 schema。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fixtures"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema 指针，供 IDE 工具链使用。"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "corpus_version": {
      "type": "string",
      "description": "整个语料库的内容版本；增删 fixture 时 bump。"
    },
    "fixtures": {
      "type": "array",
      "items": { "$ref": "#/$defs/fixture_entry" }
    }
  },
  "$defs": {
    "fixture_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "category", "expected_page_count", "sha256"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9]{2}_[a-z_]+__[a-z0-9_]+$",
          "description": "fixture 目录名；建议格式 `<两位编号>_<类别>__<slug>`。"
        },
        "path": {
          "type": "string",
          "description": "相对 corpus/ 的路径，例如 'fixtures/01_plain_text__lorem/input.pdf'。"
        },
        "category": {
          "type": "string",
          "enum": [
            "plain_text",
            "multi_column",
            "table",
            "form",
            "scanned",
            "multilang",
            "edge"
          ]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "自由标签，如 ['english','single_column','font_serif']。"
        },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "expected_page_count": { "type": "integer", "minimum": 1 },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "input.pdf 的 SHA-256（hex）。"
        },
        "source": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "url": { "type": "string" },
            "license": { "type": "string" }
          }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
