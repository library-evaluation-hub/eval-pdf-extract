{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://library-evaluation-hub/eval-pdf-extract/result-schema.json",
  "title": "PDF Extract Result",
  "description": "Adapter 输出与 ground truth 共用的 schema。orchestrator 据此做结构 diff 与评分。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pages"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "语义化版本号；adapter 与 orchestrator 必须协商一致。"
    },
    "pages": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/page" },
      "description": "允许为空数组，以表示合法的 0 页文档（如空 PDF）。"
    },
    "metadata": { "$ref": "#/$defs/document_metadata" }
  },
  "$defs": {
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_number", "text"],
      "properties": {
        "page_number": {
          "type": "integer",
          "minimum": 1,
          "description": "1-based 物理页码。"
        },
        "width": {
          "type": "number",
          "minimum": 0,
          "description": "PDF user space 宽度 (pt)。"
        },
        "height": {
          "type": "number",
          "minimum": 0,
          "description": "PDF user space 高度 (pt)。"
        },
        "text": {
          "type": "string",
          "description": "整页按 reading_order 拼接后的纯文本。用 \\n 分段。"
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" },
          "description": "页面内的块序列。允许为空（adapter 无法切分时仅填 text）。"
        },
        "tables": {
          "type": "array",
          "items": { "$ref": "#/$defs/table" },
          "description": "页面内的独立表。如果 block.type=='table' 也应在此平铺一份，便于无块信息的 consumer 使用。"
        }
      }
    },
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "bbox", "reading_order"],
      "properties": {
        "id": {
          "type": "string",
          "description": "page 内唯一 id，例如 'p1-b3'。"
        },
        "type": {
          "type": "string",
          "enum": [
            "heading",
            "paragraph",
            "list_item",
            "table",
            "image",
            "caption",
            "header",
            "footer",
            "footnote",
            "code",
            "unknown"
          ]
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "number" },
          "description": "[x0, y0, x1, y1]，PDF 坐标系（左下原点），单位 pt。"
        },
        "content": {
          "type": "string",
          "description": "块内文本内容；image 块可空。"
        },
        "reading_order": {
          "type": "integer",
          "minimum": 0,
          "description": "阅读顺序号；同页内越小越靠前。"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "description": "仅对 heading 有效。1=最高级。"
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" },
          "description": "嵌套子块（如 list_item 的子项）。"
        }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bbox", "rows"],
      "properties": {
        "id": {
          "type": "string"
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "number" }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": "二维字符串数组，rows[i][j] = 第 i 行第 j 列的文本。"
        },
        "headers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "可选的列名。"
        }
      }
    },
    "document_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title":     { "type": ["string", "null"] },
        "author":    { "type": ["string", "null"] },
        "subject":   { "type": ["string", "null"] },
        "keywords":  { "type": ["array", "null"], "items": { "type": "string" } },
        "creator":   { "type": ["string", "null"] },
        "producer":  { "type": ["string", "null"] },
        "page_count":{ "type": ["integer", "null"], "minimum": 0 },
        "ocr_used":  { "type": ["boolean", "null"] }
      }
    }
  }
}
